# ============================================
# THREADS AUTO-POST AGENT - Environment Config
# ============================================
# Copy this file to .env and fill in your values

# ─── META / THREADS API ───────────────────
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here

# Long-lived access token (from Step 7 in setup guide)
# Can also be set via THREADS_ACCESS_TOKEN
THREADS_ACCESS_TOKEN=

# Threads User ID (numeric, e.g. 17841400000000000)
# Get it from: GET /me?fields=id,username&access_token=TOKEN
THREADS_USER_ID=

# ─── DATABASE ─────────────────────────────
# Path to SQLite database (auto-created)
DB_PATH=/home/ubuntu/threads-agent/posts.db

# ─── NOTIFICATION (Telegram) ───────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Chat ID - send /start to @userinfobot to get your ID
TELEGRAM_CHAT_ID=

# ─── SCHEDULER ─────────────────────────────
# Check for pending posts every N minutes
POLL_INTERVAL_MINUTES=5

# ─── PATHS ─────────────────────────────────
SCRIPTS_DIR=/home/ubuntu/threads-agent/scripts
LOG_DIR=/home/ubuntu/threads-agent/logs

# ─── DEBUG ─────────────────────────────────
LOG_LEVEL=INFO
DRY_RUN=false
